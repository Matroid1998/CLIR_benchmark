# Copy to .env and fill in. Loaded automatically by the `clir` CLI.

# Question generation (OpenAI Chat Completions)
OPENAI_API_KEY=

# Verification / grading (Claude and others via OpenRouter)
OPENROUTER_API_KEY=

# Dataset publishing and loading from the Hugging Face Hub
HF_TOKEN=

# Google Patents extraction via BigQuery. Required by `clir ingest gp`.
# (The old repo required this but never documented it in .env.)
GOOGLE_CLOUD_PROJECT=
